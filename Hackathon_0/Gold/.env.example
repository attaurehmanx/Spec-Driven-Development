# Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!

# ============================================
# Gmail API Configuration
# ============================================
# Get credentials from: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# ============================================
# Odoo Configuration
# ============================================
# Odoo Community Edition 19+
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# ============================================
# Social Media APIs (Optional)
# ============================================

# Facebook
FACEBOOK_ACCESS_TOKEN=your_facebook_token_here
FACEBOOK_PAGE_ID=your_page_id_here

# Instagram
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
INSTAGRAM_ACCOUNT_ID=your_account_id_here

# Twitter/X
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
LINKEDIN_PERSON_URN=your_person_urn_here

# ============================================
# WhatsApp Configuration
# ============================================
# Path to Playwright session data
WHATSAPP_SESSION_PATH=./AI_Employee_Vault/whatsapp_session

# ============================================
# System Configuration
# ============================================

# Dry run mode (true = no real actions, false = execute actions)
DRY_RUN=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Check intervals (seconds)
GMAIL_CHECK_INTERVAL=120
WHATSAPP_CHECK_INTERVAL=30
LINKEDIN_CHECK_INTERVAL=300
FACEBOOK_CHECK_INTERVAL=300
INSTAGRAM_CHECK_INTERVAL=300
TWITTER_CHECK_INTERVAL=120
ODOO_CHECK_INTERVAL=600
FILESYSTEM_CHECK_INTERVAL=5

# Rate limits
MAX_EMAILS_PER_HOUR=10
MAX_SOCIAL_POSTS_PER_DAY=5
MAX_PAYMENTS_PER_DAY=3

# ============================================
# Security Settings
# ============================================

# Approval thresholds
PAYMENT_APPROVAL_THRESHOLD=50
EMAIL_APPROVAL_NEW_CONTACT=true
SOCIAL_POST_APPROVAL_REQUIRED=true

# Encryption (optional)
VAULT_ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# Backup Configuration
# ============================================

# Backup settings
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ============================================
# Monitoring & Alerts
# ============================================

# Email alerts
ALERT_EMAIL=your_email@example.com
ALERT_ON_ERROR=true
ALERT_ON_APPROVAL_NEEDED=true

# Webhook for notifications (optional)
WEBHOOK_URL=https://your-webhook-url.com/notify

# ============================================
# Development Settings
# ============================================

# Development mode
DEV_MODE=false

# Test accounts (for development)
TEST_EMAIL=test@example.com
TEST_PHONE=+1234567890

# ============================================
# Claude Code Configuration
# ============================================

# Claude API (if using API directly)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model selection
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# Notes
# ============================================
# 1. Replace all "your_*_here" values with actual credentials
# 2. Keep this file secure and never commit to git
# 3. Rotate credentials monthly
# 4. Use separate credentials for dev/prod
# 5. Enable DRY_RUN=true for testing
