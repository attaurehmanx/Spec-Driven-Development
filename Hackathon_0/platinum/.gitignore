# Platinum Tier: AI Employee .gitignore
# This ensures secrets and sensitive data are never committed

# Secrets - NEVER COMMIT
.env
*.env
.env.local
.env.production
secrets/
tokens/
credentials/
*.key
*.pem
*.crt
*.cer

# Sessions - NEVER COMMIT
*.session
*.session-*
whatsapp_session/
session_data/
session_state/
linkedin_session
linkedin_session/

# Logs - Local only
logs/
*.log
sync-logs/
npm-debug.log
yarn-error.log

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*
*.sublime-project
*.sublime-workspace

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
env/
ENV/
.venv

# Node
node_modules/
npm-debug.log
yarn-error.log
.npm
.eslintcache

# Temporary files
*.tmp
*.temp
.cache/
.tmp/
temp/

# Test and demo
demo_vault/
test_vault/
*.test
coverage/
.coverage
htmlcov/

# Docker
.docker/
docker-compose.override.yml

# Backup files
*.bak
*.backup
*.old

# Database
*.db
*.sqlite
*.sqlite3

# Certificates and keys
ssl/
certs/
private/

# Local configuration
local_config/
local_settings.py
config.local.*

# Vault state (optional - uncomment if you don't want to sync state)
# In_Progress/
# Pending_Approval/
# Approved/

# But DO sync these (for audit trail):
# Done/
# Logs/
# Updates/
credentials.json
gmail_token.json
vault/linkedin_session/ 
