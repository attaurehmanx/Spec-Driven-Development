# Platinum AI Employee Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# ENVIRONMENT SETTINGS
# ===========================================
ENVIRONMENT=local
# Options: 'cloud' or 'local'

AGENT_ROLE=approvals_and_execution
# Cloud: 'drafts_only'
# Local: 'approvals_and_execution'

# ===========================================
# VAULT SYNC (Git)
# ===========================================
GIT_REPO_URL=your-git-repository-url
GIT_EMAIL=your-email@example.com
VAULT_PATH=./vault
SYNC_INTERVAL=300
# Sync interval in seconds (default: 5 minutes)

# ===========================================
# CLOUD SECRETS (Cloud VM only)
# Local should NOT have these!
# ===========================================

# Gmail API
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=http://localhost:8080/callback

# Social Media
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=

# ===========================================
# AI CONTENT GENERATION (Google Gemini - FREE!)
# ===========================================
# Get FREE API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Options: gemini-2.5-flash (fast/free), gemini-2.0-pro (advanced)

# Odoo (Cloud VM)
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=
ODOO_DB_PASSWORD=

# ===========================================
# LOCAL SECRETS (Local machine only)
# Cloud should NOT have these!
# ===========================================

# WhatsApp Session (Local only - NEVER sync to Cloud)
WHATSAPP_SESSION_PATH=./whatsapp_session
WHATSAPP_PHONE=

# Banking Credentials (Local only - NEVER sync to Cloud)
BANKING_API_KEY=
BANKING_USERNAME=
BANKING_PASSWORD=
PAYMENT_TOKEN=
PAYMENT_GATEWAY_URL=

# Local MCP Credentials
LOCAL_MCP_API_KEY=

# ===========================================
# SECURITY SETTINGS
# ===========================================
DRY_RUN=false
# Set to 'true' to prevent actual execution (testing mode)

MAX_PAYMENT_AMOUNT=1000
# Maximum payment amount before requiring additional approval

APPROVAL_TIMEOUT=86400
# Approval timeout in seconds (default: 24 hours)

# ===========================================
# MONITORING & ALERTING
# ===========================================
ALERT_EMAIL=
# Email address for health alerts

HEALTH_CHECK_INTERVAL=60
# Health check interval in seconds

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===========================================
# CLOUD VM SETTINGS (For Local reference)
# ===========================================
CLOUD_VM_IP=
# Cloud VM public IP address

CLOUD_VM_SSH_KEY=~/.ssh/id_rsa
# SSH key for Cloud VM access

CLOUD_VM_USER=ai-employee
# SSH username for Cloud VM

# ===========================================
# DOCKER SETTINGS
# ===========================================
DOCKER_COMPOSE_PROJECT=platinum-ai-employee
# Docker Compose project name

# ===========================================
# END OF CONFIGURATION
# ===========================================
